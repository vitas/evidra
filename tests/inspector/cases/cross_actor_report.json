{
  "id": "cross_actor_report",
  "modes": ["local-mcp"],
  "steps": [
    {
      "tool": "prescribe",
      "input": {
        "actor": {"type": "agent", "id": "agent-a", "origin": "mcp"},
        "tool": "kubectl",
        "operation": "apply",
        "artifact_file": "tests/inspector/fixtures/safe-nginx-deployment.yaml"
      },
      "assert": {"ok": true}
    },
    {
      "tool": "report",
      "input": {
        "prescription_id": "{{prescription_id}}",
        "verdict": "success",
        "exit_code": 0,
        "artifact_digest": "{{artifact_digest}}",
        "actor": {"type": "agent", "id": "agent-b", "origin": "mcp"}
      },
      "assert": {
        "ok": true,
        "has_fields": ["report_id"]
      }
    },
    {
      "tool": "get_event",
      "input": {"event_id": "{{report_id}}"},
      "assert": {
        "ok": true,
        "entry_type": "report",
        "entry_actor_id": "agent-b"
      }
    }
  ]
}
