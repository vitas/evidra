{
  "id": "protocol_v1_fields",
  "steps": [
    {
      "tool": "prescribe",
      "input": {
        "actor": {
          "type": "ai_agent",
          "id": "agent-v1",
          "origin": "mcp",
          "instance_id": "pod-abc123",
          "version": "v1.3"
        },
        "tool": "kubectl",
        "operation": "apply",
        "artifact_file": "tests/inspector/fixtures/safe-nginx-deployment.yaml",
        "session_id": "session-inspector-001",
        "trace_id": "trace-inspector-001",
        "span_id": "span-prescribe-001",
        "scope_dimensions": {
          "cluster": "staging-us-east",
          "namespace": "staging"
        }
      },
      "assert": {
        "ok": true,
        "has_fields": ["prescription_id", "risk_level", "artifact_digest"]
      }
    },
    {
      "tool": "get_event",
      "input": {"event_id": "{{prescription_id}}"},
      "assert": {
        "ok": true,
        "entry_type": "prescribe",
        "entry_actor_id": "agent-v1"
      }
    },
    {
      "tool": "report",
      "input": {
        "prescription_id": "{{prescription_id}}",
        "verdict": "success",
        "exit_code": 0,
        "artifact_digest": "{{artifact_digest}}",
        "session_id": "session-inspector-001",
        "span_id": "span-report-001",
        "parent_span_id": "span-prescribe-001"
      },
      "assert": {
        "ok": true,
        "has_fields": ["report_id"]
      }
    }
  ]
}
