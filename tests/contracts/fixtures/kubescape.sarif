          {"id": "C-0034", "defaultConfiguration": {"level": "error"}}
        ]
      }
    },
    "results": [
      {
        "ruleId": "C-0034",
        "level": "error",
        "message": {"text": "Automatic mapping of service account token"},
        "locations": [{"physicalLocation": {"artifactLocation": {"uri": "deployment.yaml"}, "region": {"startLine": 1}}}]
      }
    ]
  }]
}
