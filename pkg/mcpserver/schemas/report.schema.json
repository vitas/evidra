{
  "type": "object",
  "required": ["prescription_id", "verdict"],
  "properties": {
    "prescription_id": {
      "type": "string",
      "description": "ID from prescribe response"
    },
    "verdict": {
      "type": "string",
      "enum": ["success", "failure", "error", "declined"],
      "description": "Terminal outcome of the prescribed operation or decision"
    },
    "exit_code": {
      "type": "integer",
      "description": "Exit code of the operation. Required for success/failure/error and forbidden for declined."
    },
    "decision_context": {
      "type": "object",
      "description": "Required for declined verdicts. Explains why execution was intentionally not started.",
      "required": ["trigger", "reason"],
      "properties": {
        "trigger": {
          "type": "string",
          "description": "Decision trigger class, e.g. risk_threshold_exceeded"
        },
        "reason": {
          "type": "string",
          "maxLength": 512,
          "description": "Short operational explanation for the decline"
        }
      }
    },
    "artifact_digest": {
      "type": "string",
      "description": "SHA256 of artifact actually applied (for drift detection)"
    },
    "actor": {
      "type": "object",
      "required": ["type", "id", "origin"],
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "origin": { "type": "string" },
        "instance_id": { "type": "string" },
        "version": { "type": "string" },
        "skill_version": { "type": "string", "description": "Prompt/skill contract version used by the actor" }
      }
    },
    "session_id": {
      "type": "string",
      "description": "Run/session boundary identifier (should match the prescribe session_id)"
    },
    "operation_id": {
      "type": "string",
      "description": "Operation identifier, unique within a session"
    },
    "span_id": {
      "type": "string",
      "description": "Step/span identifier within a trace"
    },
    "parent_span_id": {
      "type": "string",
      "description": "Parent span for hierarchical agent workflows"
    },
    "external_refs": {
      "type": "array",
      "description": "External reference links (e.g. GitHub run ID, Jira ticket)",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "verdict": { "const": "declined" } },
        "required": ["verdict"]
      },
      "then": {
        "required": ["decision_context"],
        "not": { "required": ["exit_code"] }
      }
    },
    {
      "if": {
        "properties": {
          "verdict": { "enum": ["success", "failure", "error"] }
        },
        "required": ["verdict"]
      },
      "then": {
        "required": ["exit_code"]
      }
    }
  ]
}
