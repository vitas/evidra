{
  "type": "object",
  "required": ["prescription_id", "exit_code"],
  "properties": {
    "prescription_id": {
      "type": "string",
      "description": "ID from prescribe response"
    },
    "exit_code": {
      "type": "integer",
      "description": "Exit code of the operation (0 = success)"
    },
    "artifact_digest": {
      "type": "string",
      "description": "SHA256 of artifact actually applied (for drift detection)"
    },
    "actor": {
      "type": "object",
      "required": ["type", "id", "origin"],
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "origin": { "type": "string" }
      }
    }
  }
}
